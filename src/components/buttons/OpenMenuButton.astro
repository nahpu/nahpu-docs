---
import cntl from "cntl";

const menuButtonClasses = cntl`
  p-2
  text-silver-tree-100
  hover:text-silver-tree-50
  bg-silver-tree-700
  dark:bg-silver-tree-200
  dark:text-silver-tree-800
  dark:hover:text-silver-tree-50
  dark:hover:bg-silver-tree-600
  hover:bg-silver-tree-600
  rounded-lg
  focus:outline-none
  focus:ring-2
  focus:ring-silver-tree-400
  transition-colors
`;
---

<button
  id="menu-button"
  type="button"
  aria-label="Open menu"
  class={menuButtonClasses}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-6 h-6"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M4 6h16M4 12h16M4 18h16"></path>
  </svg>
</button>
