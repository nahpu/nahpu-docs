---
import HomePageFeatures from "../components/HomePageFeatures.astro";
import Layout from "../layouts/Layout.astro";
import homeScreenIpad from "../assets/screenshots/home-screen-ipad.jpeg";
import siteIpad from "../assets/screenshots/site-ipad.jpeg";
import specimenRecordIphone from "../assets/screenshots/specimen-record-iphone.jpeg";
import specimenPartIphoneDark from "../assets/screenshots/specimen-part-iphone-dark.jpeg";
import cntl from "cntl";
import ImageWithFrame from "../components/ImageWithFrame.astro";

import "../styles/global.css";

const primarySectionClasses = cntl`
  pt-4
  px-4
  bg-linear-to-b from-silver-tree-200 to-silver-tree-400
  dark:from-silver-tree-900 dark:to-silver-tree-700
`;

const secondarySectionClasses = cntl`
  pt-8
  bg-silver-tree-800
  dark:bg-silver-tree-900
`;

const titleClasses = cntl`
  text-left
  text-5xl
  md:text-6xl
  font-bold
  tracking-wide
  text-silver-tree-950
  dark:text-silver-tree-50
  drop-shadow-lg
`;

const subtitleClasses = cntl`
  text-lg
  text-left
  md:text-xl
  italic
  text-silver-tree-700
  dark:text-silver-tree-200
  max-w-2xl
  pb-4
`;

const mainBtnClasses = cntl`
  px-6
  py-4
  rounded-xl
  bg-linear-to-r from-silver-tree-700 to-silver-tree-600
  dark:bg-linear-to-r dark:from-silver-tree-400 dark:to-silver-tree-300
  hover:bg-silver-tree-800 hover:to-silver-tree-700
  dark:hover:from-silver-tree-400 dark:hover:to-silver-tree-300
  text-silver-tree-100 dark:text-silver-tree-950
  font-semibold
  transition-all
  no-underline
`;

const secondaryBtnClasses = cntl`
  px-6
  py-4
  rounded-xl
  border border-silver-tree-800
  dark:border-silver-tree-400
  text-silver-tree-800
  bg-transparent
  dark:text-silver-tree-200 
  hover:bg-silver-tree-600 hover:text-white hover:border-silver-tree-400
  font-semibold transition-all
  no-underline
`;

const features = [
  {
    icon: "📸",
    title: "Digital asset management",
    desc: "Attach photos of specimens, habitats, and field notes directly to your collection records.",
  },
  {
    icon: "🐦",
    title: "Multi-taxon support",
    desc: "Mix taxa in a single project — each specimen gets a catalog format tailored to its taxon.",
  },
  {
    icon: "🌍",
    title: "Write site once, use everywhere",
    desc: "Create rich site profiles with unlimited coordinates and reuse them across specimens and events.",
  },
  {
    icon: "📅",
    title: "Collecting events",
    desc: "Document collection date, method, effort, and personnel, then link them to multiple specimens.",
  },
  {
    icon: "🧬",
    title: "Tissue sample management",
    desc: "Track large sample sets with barcode and QR scanning via the device camera.",
  },
  {
    icon: "📊",
    title: "Real-time statistics",
    desc: "Monitor activity and preservation resources to prevent over-collection at a glance.",
  },
  {
    icon: "🔄",
    title: "Advanced sharing",
    desc: "Share data with collaborators or pipe it automatically into a museum database.",
  },
  {
    icon: "💪",
    title: "Open source & open standards",
    desc: "Built on open-source stacks, following Darwin Core and FAIR principles.",
  },
];
---

<Layout
  title="NAHPU Documentation"
  description="Revolutionizing Field Expeditions with a Digital Catalog for Everyone"
>
  <section class={primarySectionClasses}>
    <div class="flex flex-col lg:flex-row items-center gap-24 justify-center">
      <div id="text-hero" class="lg:pb-2">
        <h1 class={titleClasses}>NAHPU</h1>
        <h2 class={subtitleClasses}>
          A cross-platform digital field catalog for natural history collections
        </h2>

        <div class="flex flex-wrap gap-4 justify-left">
          <a href="/en" class={mainBtnClasses}>Learn NAHPU</a>
          <a href="/en/installation" class={secondaryBtnClasses}>Try NAHPU</a>
        </div>
      </div>
      <div
        id="image-hero"
        class="rounded-t-2xl overflow-hidden flex lg:self-end"
      >
        <ImageWithFrame
          src={homeScreenIpad}
          darkSrc={siteIpad}
          alt="NAHPU Home Screen"
          width={600}
        />
      </div>
    </div>
  </section>
  <section class={secondarySectionClasses}>
    <div class="flex flex-col lg:flex-row items-center gap-2 justify-center">
      <div class="flex lg:self-end order-last lg:order-first">
        <ImageWithFrame
          src={specimenRecordIphone}
          darkSrc={specimenPartIphoneDark}
          alt="NAHPU Specimen Record"
          width={200}
        />
      </div>
      <div class="pb-4 ml-8">
        <HomePageFeatures />
      </div>
    </div>
  </section>

  <section class="py-8 bg-silver-tree-400 dark:bg-silver-tree-950">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-white mb-10">
        Key Features
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          features.map(({ icon, title, desc }) => (
            <div class="flex flex-col gap-2 bg-silver-tree-200 dark:bg-silver-tree-800 rounded-xl p-5 transition-shadow">
              <div>
                <span class="text-3xl">{icon}</span>
                <h3 class="font-semibold text-silver-tree-900 dark:text-silver-tree-50">
                  {title}
                </h3>
              </div>
              <p class="text-sm text-silver-tree-700 dark:text-silver-tree-200 leading-relaxed">
                {desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
