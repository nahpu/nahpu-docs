---
import HomePageFeatures from "../components/HomePageFeatures.astro";
import HomeLayout from "../layouts/Layout.astro";
import "../styles/tailwind.pages.css";
---

<HomeLayout
  title="NAHPU Documentation"
  description="Revolutionizing Field Expeditions with a Digital Catalog for Everyone"
>
  <section
    class="flex flex-col items-center justify-center text-center px-4 py-28 bg-linear-to from-gray-900 to-gray-950"
  >
    <!-- <img src="/src/assets/nahpu.svg" alt="NAHPU logo" class="w-24 h-24 mb-6" /> -->
    <h1 class="text-5xl font-bold tracking-tight mb-4">NAHPU</h1>
    <p class="text-xl font-bold text-gray-400 max-w-xl mb-10">
      Rethinking species inventory in the digital age
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href="/en"
        class="px-6 py-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-colors"
      >
        Learn NAHPU
      </a>
      <a
        href="/en/installation"
        class="px-6 py-3 rounded-lg border border-blue-500 text-blue-400 hover:bg-blue-500 hover:text-white font-semibold transition-colors"
      >
        Install
      </a>
    </div>
  </section>
  <section class="py-16 bg-gray-100 dark:bg-gray-800">
    <div class="container mx-auto px-4">
      <HomePageFeatures />
    </div>
  </section>
</HomeLayout>
