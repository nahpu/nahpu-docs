---
import HomePageFeatures from "../components/HomePageFeatures.astro";
import HomeLayout from "../layouts/Layout.astro";
import "../styles/global.css";
import cntl from "cntl";

const primarySectionClasses = cntl`
  flex
  flex-col
  items-center
  justify-center
  text-center
  px-4
  py-28
  bg-linear-to-b from-silver-tree-950 via-silver-tree-900 to-silver-tree-700
  dark:from-silver-tree-950 dark:via-silver-tree-900 dark:to-silver-tree-600
`;

const titleClasses = cntl`
  text-5xl
  md:text-6xl
  font-bold
  tracking-tight
  mb-4
  text-white
  drop-shadow-lg
`;

const subtitleClasses = cntl`
  text-lg
  md:text-xl
  italic
  text-silver-tree-100
  max-w-xl
  mb-10
`;

const mainBtnClasses = cntl`
  px-6
  py-3
  rounded-lg
  bg-linear-to-r from-silver-tree-500 to-silver-tree-400
  hover:from-silver-tree-400 hover:to-silver-tree-300
  text-white
  font-semibold
  transition-all
  shadow-lg hover:shadow-xl
  no-underline
`;

const secondaryBtnClasses = cntl`
  px-6
  py-3
  rounded-lg
  border-2 border-silver-tree-300
  text-silver-tree-100 bg-silver-tree-800/50 backdrop-blur-sm
  hover:bg-silver-tree-600 hover:text-white hover:border-silver-tree-400
  font-semibold transition-all shadow-lg hover:shadow-xl
  no-underline
`;

const secondarySectionClasses = cntl`
  py-16
  bg-silver-tree-900/50
  dark:bg-silver-tree-800/50
`;
---

<HomeLayout
  title="NAHPU Documentation"
  description="Revolutionizing Field Expeditions with a Digital Catalog for Everyone"
>
  <section class={primarySectionClasses}>
    <h1 class={titleClasses}>NAHPU</h1>
    <p class={subtitleClasses}>
      Rethinking species inventory in the digital age
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href="/en" class={mainBtnClasses}> Learn NAHPU </a>

      <a href="/en/installation" class={secondaryBtnClasses}> Install </a>
    </div>
  </section>

  <section class={secondarySectionClasses}>
    <div class="container mx-auto px-4">
      <HomePageFeatures />
    </div>
  </section>
</HomeLayout>
